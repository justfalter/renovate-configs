{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "description": ["my test renovate config"],
    "printConfig": true,
    "packageRules": [
        {
            "matchSourceUrls": ["https://github.com/aws/aws-sdk-js-v3{/**,}"],
            "fetchChangeLogs": "off",
            "prBodyNotes": [
                "> [!IMPORTANT]\n> This is a prBodyNote for aws/aws-sdk-js-v3."
            ]
        },
        {
            "matchSourceUrls": ["*"],
            "prBodyNotes": [
                "This is a test prBodyNote."
            ]
        },
        {
            "matchSourceUrls": ["https://github.com/aws/aws-sdk-go-v2{/**,}"],
            "fetchChangeLogs": "off",
            "prBodyNotes": [
                "> [!IMPORTANT]\n> Fetching of changelogs for aws/aws-sdk-go-v2 packages are explicitly disabled via [this rule here](https://github.com/justfalter/renovate-configs/blob/main/disable.md)"
            ]
        }
    ]
  }
